{
  "name": "sentinel",
  "version": "1.0.0",
  "private": true,
  "description": "Sentinel Decision Systems - ML-powered financial decisioning platform",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "api": "cd backend && uvicorn app.main:app --reload --port 8000",
    "api:prod": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000"
  },
  "keywords": [
    "fintech",
    "decisioning",
    "ml",
    "fraud",
    "credit-risk"
  ],
