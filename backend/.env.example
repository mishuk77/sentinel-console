# ============================================================
# LOCAL DEVELOPMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values
# This is ONLY for local development
# For Railway/Vercel production, set these in their dashboards
# ============================================================

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=Sentinel Decision Systems
DEBUG=true
ENV=local

# Database (local Docker PostgreSQL)
# Note: Using synchronous SQLAlchemy, so use postgresql:// not postgresql+asyncpg://
DATABASE_URL=postgresql://sentinel:sentinel_local@localhost:5432/sentinel

# Security
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# CORS - Frontend URLs that can access the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage - Use local filesystem for development
STORAGE_TYPE=local

# ============================================================
# OPTIONAL: AWS S3 Storage (only if you want to use S3)
# For Railway production: use Railway volume storage OR S3
# Comment these out if using local storage
# ============================================================
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1
# S3_BUCKET=sentinel-datasets
